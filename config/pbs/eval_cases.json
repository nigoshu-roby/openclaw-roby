[
  {
    "id": "qa_greeting_local",
    "description": "ローカル挨拶応答が動くこと",
    "message": "こんにちは",
    "route": "auto",
    "execute": true,
    "expect": {
      "equals": {
        "route": "qa_gemini",
        "action.ok": true,
        "action.mode": "local_greeting"
      },
      "contains": {
        "action.output": ["こんにちは", "対応できます"]
      },
      "min_len": {
        "action.output": 20
      }
    }
  },
  {
    "id": "coding_handoff_ready",
    "description": "実装依頼が coding_codex に分類され、要件JSONが生成されること",
    "message": "チャット欄のUXを改善して",
    "route": "auto",
    "execute": false,
    "expect": {
      "equals": {
        "route": "coding_codex",
        "action.executed": false
      },
      "contains": {
        "action.requirements.objective": ["チャット欄", "UX"]
      }
    }
  },
  {
    "id": "minutes_route_ready",
    "description": "議事録依頼が minutes_pipeline に分類され、実行コマンドが組み立てられること",
    "message": "TOKIWAGIの議事録からタスク化して",
    "route": "auto",
    "execute": false,
    "expect": {
      "equals": {
        "route": "minutes_pipeline",
        "action.executed": false,
        "action.mode": "run"
      },
      "contains": {
        "action.command": ["roby-minutes.py", "--run"]
      }
    }
  },
  {
    "id": "qa_local_status_ollama",
    "description": "Ollama導入確認がローカル自己把握で回答されること",
    "message": "ollama導入できましたか？",
    "route": "auto",
    "execute": true,
    "expect": {
      "equals": {
        "route": "qa_ollama",
        "action.ok": true,
        "action.mode": "local_status"
      },
      "contains": {
        "action.output": ["Ollama CLI", "Ollama API", "Neuronic endpoint"]
      },
      "not_contains": {
        "action.output": ["持ち合わせていません", "情報はありません", "Unable to"]
      },
      "min_len": {
        "action.output": 80
      }
    }
  },
  {
    "id": "qa_local_status_neuronic",
    "description": "Neuronic連携確認が実環境ステータスで返ること",
    "message": "Neuronicとの連携は？",
    "route": "qa_gemini",
    "execute": true,
    "expect": {
      "equals": {
        "route": "qa_gemini",
        "action.ok": true,
        "action.mode": "local_status"
      },
      "contains": {
        "action.output": ["Neuronic endpoint", "利用可能ルート"]
      },
      "not_contains": {
        "action.output": ["情報はありません", "具体的な内容をお聞かせください"]
      },
      "min_len": {
        "action.output": 100
      }
    }
  },
  {
    "id": "qa_feature_list_quality",
    "description": "機能一覧要求で構造化された回答が返ること",
    "message": "現在の機能をリスト化してください",
    "route": "auto",
    "execute": true,
    "expect": {
      "equals": {
        "route": "qa_gemini",
        "action.ok": true
      },
      "contains": {
        "action.output": ["## 目的", "## 次のアクション"]
      },
      "not_contains": {
        "action.output": ["Extracted content length", "Hard limit", "Let's look at the prompt"]
      },
      "min_len": {
        "action.output": 120
      }
    }
  },
  {
    "id": "qa_no_prompt_leak_for_detailed_question",
    "description": "詳細相談時にプロンプト断片漏れ/途中切れを起こさないこと",
    "message": "現在の機能をリスト化してください。詳細版でお願いします。",
    "route": "auto",
    "execute": true,
    "expect": {
      "equals": {
        "route": "qa_gemini",
        "action.ok": true
      },
      "contains": {
        "action.output": ["## 目的", "## 実行可能な提案（優先順）", "## 次のアクション"]
      },
      "not_contains": {
        "action.output": ["Extracted content length", "Hard limit", "Let's look at the prompt"]
      },
      "min_len": {
        "action.output": 180
      }
    }
  }
